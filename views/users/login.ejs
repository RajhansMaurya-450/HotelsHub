    <div class="row mt-5 mb-5">

        <div class="col-lg-4 col-md-6 col-10 mx-auto">

            <div class="card shadow-lg border-0 p-4 rounded-4">

                <h2 class="text-center mb-4"><i class="fa-solid fa-arrow-right-to-bracket"></i>&nbsp;Login into Hotels
                    Hub</h2>

                <form method="POST" action="/login" class="needs-validation" novalidate>

                    <div class="mb-3">
                        <label for="username" class="form-label fw-semibold">Username</label>
                        <input type="text" class="form-control form-control-lg" id="username" name="username"
                            placeholder="Enter your username" required>
                        <div class="valid-feedback">Looks Good</div>
                        <div class="invalid-feedback">Enter a valid Username!</div>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label fw-semibold">Password</label>
                        <input type="password" class="form-control form-control-lg" id="password" name="password"
                            placeholder="Enter your password" required>
                        <div class="valid-feedback">Looks Good</div>
                        <div class="invalid-feedback">Password cannot be empty!</div>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 mt-3 rounded-pill">
                        Log In
                    </button>

                </form>

            </div>

        </div>

    </div>