<% layout("/layouts/boilerplate.ejs") %>

<script>
const coordinates = <%- JSON.stringify(singleData.geometry.coordinates) %>;
const Hotel_Name = "<%= singleData.title %>";
const GEOAPIFY_API_KEY = process.env.GEOAPIFY_API_KEY;

</script>


   <div class="row mt-3">
      <div class="col-8 offset-2">
         <b>
            <h3> <i>
                  <%= singleData.title %>
               </i></h3>
         </b>
      </div>
      <div class="col-6 offset-2">

         <body>
            <div class="card listing-card">
               <img src="<%= singleData.image.url %>" class="card-img-top show-img" alt="hotel image">
               <div class="card-body">
                  <p class="card-text">
                     <u><b>Property Listed By</u>: </b>
                     <%= singleData.owner[0].username %> <br><br>
                        <%= singleData.description %><br />
                           ₹<%= singleData.price.toLocaleString("en-IN") %> <br />
                              <%= singleData.location %><br />
                                 <%= singleData.country %>
                                    <br />
                  </p>
                  <% if ( currUser && singleData.owner && singleData.owner.some(owner=> owner._id.toString() ===
                     currUser._id.toString())
                     ) { %>

                     <div class="d-flex gap-2 mt-3">

                        <form method="GET" action="/listings/<%=singleData._id%>/edit">
                           <button type="submit" class="btn btn-primary">Edit</button>
                        </form>


                        <form method="POST" action="/listings/<%=singleData._id%>?_method=DELETE">
                           <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                     </div>
                     <% } %>

                        <div>
                           <hr>
                           <h3>Property Location:</h3>
                           <div id="my-map" style="height: 400px; width: 100%;"></div>
                           <hr>
                           <% if(currUser) {%>
                              <h4>
                                 Share your experience with us!
                              </h4>
                              <form method="POST" action="/listingData/<%=singleData._id%>/reviews" novalidate
                                 class="needs-validation">
                                 <label for="rating">Rating:</label>
                                 <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                       value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                 </fieldset>

                                 <label for="Comment">Comments:</label><br>
                                 <textarea id="Comment" name="review[Comment]" cols="70" rows="4" required></textarea>
                                 <div class="invalid-feedback">Required field cannot be empty!</div><br><br>
                                 <button type="submit" class="btn btn-success">Submit</button>
                              </form>
                              <hr>
                              <% } %>

                                 <p><b>Reviews</b></p>
                                 <div class="row">
                                    <% for(review of singleData.reviews) { %>
                                       <div class="card col-5 ms-3 mb-3">
                                          <div class="card-body">

                                             <h5 class="card-title">@<%= review.author.username %>
                                             </h5>
                                             <p class="starability-result card-text" data-rating="<%= review.rating %>">
                                                <%= review.rating %>
                                             </p>

                                             <p class="card-text">
                                                <%= review.Comment %>
                                             </p>

                                             <form class="mb-3" method="post"
                                                action="/listingData/<%=singleData._id%>/reviews/<%= review._id %>?_method=DELETE">
                                                <button class="btn btn-danger btn-sm mb-3">Delete</button>
                                             </form>
                                          </div>
                                       </div>
                                       <% } %>
                                 </div>




                        </div>

               </div>
            </div>
      </div>

   </div>

   </body>
   
   <script> 

      const map = new maplibregl.Map({
         container: 'my-map',
         style: 'https://maps.geoapify.com/v1/styles/klokantech-basic/style.json?apiKey=`${GEOAPIFY_API_KEY}`',
         center: coordinates,
         zoom: 14
      });

      map.addControl(new maplibregl.NavigationControl());

      new maplibregl.Marker({color:"red"})
         .setLngLat(coordinates)
         .setPopup(new maplibregl.Popup().setText(Hotel_Name))
         .addTo(map);

   </script>