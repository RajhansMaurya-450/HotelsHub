<% layout("/layouts/boilerplate.ejs") %>

   <div class="row mt-3">
      <div class="col-8 offset-2">
         <b>
            <h3> <i>
                  <%= singleData.title %>
               </i></h3>
         </b>
      </div>
      <div class="col-6 offset-2">

         <body>
            <div class="card listing-card">
               <img src="<%= singleData.image.url %>" class="card-img-top show-img" alt="hotel image">
               <div class="card-body">
                  <p class="card-text">
                     <u><b>Property Listed By</u>: </b><%= singleData.owner[0].username %> <br><br>
                        <%= singleData.description %><br />
                           ₹<%= singleData.price.toLocaleString("en-IN") %> <br />
                              <%= singleData.location %><br />
                                 <%= singleData.country %>
                                    <br />
                  </p>


                  <div class="d-flex gap-2 mt-3">
                     
                     <form method="GET" action="/listings/<%=singleData._id%>/edit">
                        <button type="submit" class="btn btn-primary">Edit</button>
                     </form>


                     <form method="POST" action="/listings/<%=singleData._id%>?_method=DELETE">
                        <button type="submit" class="btn btn-danger">Delete</button>
                     </form>
                  </div>
                  
                  <div>
                     <hr>
                     <h4>
                        Share your experience with us!
                     </h4>
                     <form method="POST" action="/listingData/<%=singleData._id%>/reviews" novalidate
                        class="needs-validation">
                        <label for="rating">Rating:</label>
                        <input type="range" id="rating" name="review[rating]" min="1" max="5"><br><br>

                        <label for="Comment">Comments:</label><br>
                        <textarea id="Comment" name="review[Comment]" cols="70" rows="4" required></textarea>
                        <div class="invalid-feedback">Required field cannot be empty!</div><br><br>
                        <button type="submit" class="btn btn-success">Submit</button>
                     </form>
                     <hr>
                     <p><b>Reviews</b></p>
                     <div class="row">
                        <% for(review of singleData.reviews) { %>
                           <div class="card col-5 ms-3 mb-3">
                              <div class="card-body">
                                 <h5 class="card-title">Tony Stank</h5>
                                 <p class="card-text">
                                    <%= review.Comment %>
                                 </p>

                                 <p class="card-text">
                                    <%= review.rating %> Stars
                                 </p>
                                 <form class="mb-3" method="post"
                                    action="/listingData/<%=singleData._id%>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-danger btn-sm mb-3">Delete</button>
                                 </form>
                              </div>
                           </div>
                           <% } %>
                     </div>




                  </div>

               </div>
            </div>
      </div>

   </div>
   </body>