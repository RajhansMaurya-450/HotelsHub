<% layout("/layouts/boilerplate.ejs") %>

<script>
const coordinates = <%- JSON.stringify(singleData.geometry.coordinates) %>;
const Hotel_Name = "<%= singleData.title %>";
const GEOAPIFY_API_KEY = "<%= process.env.GEOAPIFY_API_KEY %>";
</script>

<div class="container my-4">
   
  <div class="row justify-content-center mb-3">
   
    <div class="col-lg-10 col-12">
      <h2 class="fw-bold mb-4"><%= singleData.title %></h2>
      
      <img src="<%= singleData.image.url %>" class="img-fluid w-100 rounded-4" style="max-height:420px; object-fit:cover;" alt="hotel image">
    </div>
  </div>

  
  <div class="row g-4">

   
    <div class="col-lg-7">

      
      <div class="card shadow-sm border rounded-4 mb-4">
        <div class="card-body p-4">
          <p class="text-muted mb-1">
            <strong class="text-dark">Hosted by:</strong> @<%= singleData.owner[0].username %>
          </p>
          <hr>
          <p class="card-text"><%= singleData.description %></p>
          <p class="fw-bold fs-4" style="color:#22a742;">₹<%= singleData.price.toLocaleString("en-IN") %></p>
          <p class="mb-1"><strong>Location:</strong> <%= singleData.location %></p>
          <p class="mb-0"><strong>Country:</strong> <%= singleData.country %></p>

          <% if (currUser && singleData.owner && singleData.owner.some(owner => owner._id.toString() === currUser._id.toString())) { %>
            <hr>
            <div class="d-flex gap-2">
              <form method="GET" action="/listings/<%= singleData._id %>/edit">
                <button type="submit" class="btn btn-primary btn-sm px-5">Edit</button>
              </form>
              <form method="POST" action="/listings/<%= singleData._id %>?_method=DELETE">
                <button type="submit" class="btn btn-danger btn-sm px-5">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>

      
      <h5 class="fw-bold mb-3">Reviews</h5>

      <% if (singleData.reviews && singleData.reviews.length > 0) { %>
        <% for (let review of singleData.reviews) { %>
          <div class="card shadow-sm border rounded-4 mb-3">
            <div class="card-body p-3">
              <h6 class="fw-bold mb-1">@<%= review.author.username %></h6>
              <p class="starability-result mb-2" data-rating="<%= review.rating %>"><%= review.rating %>/5</p>
              <p class="card-text text-muted mb-3"><%= review.Comment %></p>
              <form method="post" action="/listingData/<%= singleData._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <div class="text-center text-muted border rounded-4 p-4">
          No reviews yet. Be the first to share your experience!
        </div>
      <% } %>

    </div>

   
    <div class="col-lg-5">
      <div class="sticky-top" style="top: 75px; z-index: 100;">

        
        <div class="card shadow-sm border rounded-4 mb-4 overflow-hidden">
          <div class="card-header bg-white border-bottom d-flex align-items-center gap-2 py-2">
            <span>📍</span>
            <small class="fw-semibold">Location Map</small>
          </div>
          <div id="my-map" style="height:220px; width:100%;"></div>
          <button class="btn btn-light border-top w-100 rounded-0 py-2 fw-semibold small" id="openMapModal">
            <span class="text-danger">📍</span> View Full Map
          </button>
        </div>

       
        <% if (currUser) { %>
          <div class="card shadow-sm border rounded-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-3">Add Review</h5>
              <form method="POST" action="/listingData/<%= singleData._id %>/reviews" novalidate class="needs-validation">

                <label class="form-label fw-semibold">Rating</label>
                <fieldset class="starability-slot mb-3">
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                  <label for="first-rate2" title="Not good">2 stars</label>
                  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                  <label for="first-rate4" title="Very good">4 stars</label>
                  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>

                <label class="form-label fw-semibold" for="Comment">Your Feedback</label>
                <textarea id="Comment" name="review[Comment]" class="form-control mb-1" rows="4" placeholder="Write your feedback..." required></textarea>
                <div class="invalid-feedback mb-2">Required field cannot be empty!</div>

                <button type="submit" class="btn btn-success w-100 mt-2 py-2 fw-bold">Submit</button>
              </form>
            </div>
          </div>
        <% } %>

      </div>
    </div>

  </div>
</div>


<div id="mapModal" class="position-fixed top-0 start-0 w-100 h-100 align-items-center justify-content-center" style="display:none; z-index:9999; background:rgba(0,0,0,0.7); backdrop-filter:blur(6px);">
  <div class="bg-white rounded-4 overflow-hidden shadow-lg d-flex flex-column" style="width:90vw; max-width:900px; height:80vh;">
    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
      <strong>📍 <%= singleData.title %> — Location</strong>
      <button id="closeMapModal" class="btn btn-light btn-sm rounded-circle border" style="width:36px;height:36px;">✕</button>
    </div>
    <div id="full-map" class="flex-grow-1 w-100"></div>
  </div>
</div>


<script>
  /* ── Inline sidebar map ── */
  const map = new maplibregl.Map({
    container: 'my-map',
    style: `https://maps.geoapify.com/v1/styles/klokantech-basic/style.json?apiKey=${GEOAPIFY_API_KEY}`,
    center: coordinates,
    zoom: 14
  });
  map.addControl(new maplibregl.NavigationControl());
  new maplibregl.Marker({ color: "red" })
    .setLngLat(coordinates)
    .setPopup(new maplibregl.Popup().setText(Hotel_Name))
    .addTo(map);

  /* ── Full-screen modal map ── */
  let fullMap = null;
  const modal = document.getElementById('mapModal');

  document.getElementById('openMapModal').addEventListener('click', function () {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    if (!fullMap) {
      fullMap = new maplibregl.Map({
        container: 'full-map',
        style: `https://maps.geoapify.com/v1/styles/klokantech-basic/style.json?apiKey=${GEOAPIFY_API_KEY}`,
        center: coordinates,
        zoom: 14
      });
      fullMap.addControl(new maplibregl.NavigationControl());
      fullMap.addControl(new maplibregl.FullscreenControl());
      new maplibregl.Marker({ color: "red" })
        .setLngLat(coordinates)
        .setPopup(new maplibregl.Popup().setText(Hotel_Name))
        .addTo(fullMap);
    } else {
      setTimeout(() => fullMap.resize(), 50);
    }
  });

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.getElementById('closeMapModal').addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) { if (e.target === this) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
</script>
